{
  "name": "radiobiocalc-app",
  "version": "2.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 EXPO_PORT=8081 npx expo start --web --port 8081",
    "dev:mobile": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:server": "cross-env NODE_ENV=development PORT=3000 tsx server/_core/index.ts",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:phase2a": "tsx scripts/run_phase2a_test.ts",
    "test:cycle": "tsx scripts/run_phase_cycle.ts",
    "test:phase2b": "tsx scripts/run_phase2b_test.ts",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build -p android --profile preview",
    "build:pilot-apk": "eas build -p android --profile pilot --non-interactive",
    "build:offline-apk": "eas build -p android --profile offline --non-interactive",
    "build:mobile-apk": "eas build -p android --profile offline --non-interactive",
    "build:mobile-ios": "eas build -p ios --profile offline --non-interactive",
    "build:mobile-all": "eas build -p android --profile offline --non-interactive && eas build -p ios --profile offline --non-interactive",
    "test:offline-engine": "tsx scripts/run_offline_engine_test.ts",
    "test:report-export": "tsx scripts/run_report_export_test.ts",
    "test:dvh-parse": "tsx scripts/run_dvh_parse_test.ts",
    "test:ci": "npm run test:offline-engine && npm run test:report-export && npm run test:dvh-parse && npm run test:phase2a && npm run test:phase2b && vitest run",
    "build:android:local": "cross-env EXPO_PUBLIC_OFFLINE_BUILD=1 expo prebuild --platform android && cross-env EXPO_PUBLIC_OFFLINE_BUILD=1 npm run build:android:gradle",
    "build:android:local:clean": "cross-env EXPO_PUBLIC_OFFLINE_BUILD=1 expo prebuild --platform android --clean && cross-env EXPO_PUBLIC_OFFLINE_BUILD=1 npm run build:android:gradle",
    "build:android:gradle": "cd android && gradlew.bat assembleRelease",
    "test:bluestacks": "powershell -ExecutionPolicy Bypass -File scripts/bluestacks_smoke_test.ps1",
    "clean:expo-cache": "node -e \"const fs=require('fs');['.expo','dist','web-build'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true});console.log('removed',d)}catch(e){}})\"",
    "build:ios": "eas build -p ios --profile preview",
    "prebuild": "expo prebuild --clean",
    "qr": "node scripts/generate_qr.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.8.12",
    "@react-navigation/elements": "^2.9.2",
    "@react-navigation/native": "^7.1.25",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "11.7.2",
    "@trpc/react-query": "11.7.2",
    "@trpc/server": "11.7.2",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "expo": "~54.0.29",
    "expo-audio": "~1.1.0",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.12",
    "expo-document-picker": "^14.0.8",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-notifications": "~0.32.15",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.19",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.15",
    "expo-web-browser": "~15.0.10",
    "express": "^4.22.1",
    "jose": "6.1.0",
    "mysql2": "^3.16.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "superjson": "^1.13.3",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.17",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.7.4",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "optionalDependencies": {
    "lightningcss-win32-x64-msvc": "^1.32.0"
  }
}
