# API (required for iOS/Android physical devices — use your PC LAN IP)
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:3000

# Server
PORT=3000
JWT_SECRET=change-me-in-production

# Database (optional — auth only; calculations work without DB)
DATABASE_URL=mysql://user:password@127.0.0.1:3306/radiobiocalc

# OAuth (optional — app works offline for DVH calculations)
EXPO_PUBLIC_OAUTH_PORTAL_URL=
EXPO_PUBLIC_OAUTH_SERVER_URL=
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_OWNER_OPEN_ID=
EXPO_PUBLIC_OWNER_NAME=
